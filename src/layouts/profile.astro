---
import "../styles/global.css";
import Main from "./main.astro";
import Header from "../components/Header.astro";
import Legal from "../components/Legal.astro";
import Social from "../components/Social.astro";
import { getCollection } from 'astro:content';

interface ProfileFrontmatter {
  title: string;
  name: string;
  role?: string;
  avatar?: string;
  location?: string;
}

const { content } = Astro.props as { content: ProfileFrontmatter };

// Get events where this artisan participates
const allEvents = await getCollection('events');
const artisanEvents = allEvents.filter(event => 
  event.data.participants.includes(content.title)
).map(entry => ({
  id: entry.id,
  slug: entry.slug,
  title: entry.data.title,
  description: entry.body || '',
  startTime: entry.data.startTime,
  endTime: entry.data.endTime,
  location: entry.data.location,
  participants: entry.data.participants,
}));
---

<Main content={{ title: `${content.name} (@${content.title})` }}>
  <body class:list={["bg-background flex h-screen flex-col", "overflow-auto"]}>
    <Header />
    <main class="flex-1">
      <div class="container mx-auto max-w-2xl px-4 py-8">
        <header class="mb-12 text-center">
          <div
            class="mb-6 inline-flex h-32 w-32 items-center justify-center overflow-hidden rounded-full bg-stone-300 dark:bg-stone-700"
          >
            {
              content.avatar ? (
                <img
                  src={content.avatar}
                  alt={content.name}
                  class="h-full w-full object-cover"
                />
              ) : (
                <span class="font-serif text-4xl text-stone-600 dark:text-stone-300">
                  {content.name.charAt(0)}
                </span>
              )
            }
          </div>

          <h1
            class="mb-2 text-3xl font-bold"
            style="font-family: 'Libre Baskerville', serif;"
          >
            {content.name}
          </h1>

          {
            content.role && (
              <p class="mb-2 text-lg text-stone-600 dark:text-stone-400">
                {content.role}
              </p>
            )
          }

          <p class="text-stone-500 dark:text-stone-500">
            @{content.title}
          </p>

          {
            content.location && (
              <p class="mt-2 text-sm text-stone-400 dark:text-stone-500">
                📍 {content.location}
              </p>
            )
          }
        </header>

        <article class="prose prose-stone dark:prose-invert prose-lg mx-auto">
          <slot />
        </article>

        {/* Events Section */}
        {artisanEvents.length > 0 && (
          <section class="mt-12">
            <h2 class="text-2xl font-bold mb-6" style="font-family: 'Libre Baskerville', serif;">
              Veranstaltungen
            </h2>
            <div class="space-y-4">
              {artisanEvents.map(event => (
                <div class="bg-card rounded-lg p-4 border border-border">
                  <h3 class="text-lg font-semibold mb-2">{event.title}</h3>
                  <p class="text-sm text-muted-foreground mb-2">
                    📍 {event.location.name}
                  </p>
                  <p class="text-sm text-muted-foreground">
                    {new Date(event.startTime).toLocaleDateString('de-DE')} - {new Date(event.endTime).toLocaleDateString('de-DE')}
                  </p>
                  {event.description && (
                    <p class="text-sm mt-2 text-foreground">{event.description}</p>
                  )}
                </div>
              ))}
            </div>
          </section>
        )}
      </div>
    </main>
    <footer
      class="container mx-auto flex-none px-4 py-4 text-center text-sm text-stone-600 dark:text-stone-400"
    >
      <Social />
      <Legal />
    </footer>
  </body>
</Main>
