---
import "../styles/global.css";
import Main from "../layouts/main.astro";
const { content } = Astro.props;
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import App from "../components/App";
import { getCollection } from 'astro:content';

const eventsCollection = await getCollection('events');
const events = eventsCollection.map(entry => ({
  id: entry.id,
  slug: entry.slug,
  title: entry.data.title,
  description: entry.body || '',
  startTime: entry.data.startTime,
  endTime: entry.data.endTime,
  location: entry.data.location,
  participants: entry.data.participants,
}));
---

<Main content={{ title: "ains.art" }}>
  <body class="bg-background fixed inset-0 flex h-dvh w-full overflow-hidden">
    <Header />
    <App client:only="react" events={events} />
  </body>
</Main>
